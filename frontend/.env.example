# Frontend configuration (copy to frontend/.env.local).
#
# Local dev: leave these UNSET — Vite proxies /api and /ws to the backend on
# :8000 (see vite.config.ts), so the app uses same-origin relative URLs.
#
# Production (Vercel): point these at the deployed backend.
# VITE_API_URL=https://your-backend.onrender.com
# VITE_WS_URL=wss://your-backend.onrender.com/ws/stream
