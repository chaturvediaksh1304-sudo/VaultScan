# Production build defaults (used by `vite build` / Vercel).
# Always-on, self-contained demo: replay real model scores client-side so the
# live site never waits on a backend. To run the prod build against a real
# backend instead, set VITE_DEMO_MODE=false and provide VITE_API_URL/VITE_WS_URL.
VITE_DEMO_MODE=true
