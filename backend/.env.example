# Backend configuration (copy to backend/.env or export before running).
# This simplified build streams transactions in-process — no Kafka/Postgres/Redis
# are required. The vars below are the only ones that affect runtime.

# Transactions per second the in-process simulator replays.
REPLAY_SPEED_TPS=10

# Comma-separated allowed CORS origins (the deployed frontend + local dev).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
